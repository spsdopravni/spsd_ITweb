# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================================
# Dependencies
# ============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================================
# Next.js
# ============================================================================
/.next/
/out/
/dist/
/build

# ============================================================================
# Testing
# ============================================================================
/coverage
*.log

# ============================================================================
# Environment Variables (NEVER COMMIT!)
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Allow .env.example to be committed
!.env.example

# ============================================================================
# Database
# ============================================================================
# Prisma
*.db
*.db-journal
*.sqlite

# PostgreSQL dumps
*.sql
*.dump

# ============================================================================
# Logs
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# ============================================================================
# IDE / Editor
# ============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Claude Code
.claude/

# ============================================================================
# TypeScript
# ============================================================================
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# Vercel
# ============================================================================
.vercel

# ============================================================================
# Temporary Files
# ============================================================================
tmp/
temp/
*.tmp
*.temp
/tmp
.cache

# ============================================================================
# Test Scripts & Local Files
# ============================================================================
test-login.sh
*.local.md

# ============================================================================
# Security & Sensitive Files
# ============================================================================
# Keys and certificates
*.key
*.pem
*.cert
*.crt
*.csr
*.p12
*.pfx

# Credentials
credentials.json
secrets.json
.secrets/

# Backup files
*.backup
*.bak
*.old

# ============================================================================
# Build Artifacts
# ============================================================================
dist-ssr
*.local
