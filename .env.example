# ============================================================================
# SPŠD IT Web - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!
# ============================================================================

# ----------------------------------------------------------------------------
# App Configuration
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
# Local development example:
# DATABASE_URL="postgresql://username:password@localhost:5432/spsd_itweb?schema=public"
#
# Production (Supabase, Railway, etc.):
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"
DATABASE_URL="postgresql://postgres:password@localhost:5432/spsd_itweb"

# ----------------------------------------------------------------------------
# JWT Secrets
# ----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-minimum-32-characters-long-change-this"

# ----------------------------------------------------------------------------
# Microsoft OAuth (Azure AD / Entra ID)
# ----------------------------------------------------------------------------
# Get these from Azure Portal: https://portal.azure.com
# 1. Go to "Azure Active Directory" → "App registrations"
# 2. Create new app registration
# 3. Set redirect URI: http://localhost:3000/api/auth/callback
# 4. Copy Application (client) ID
# 5. Create new client secret in "Certificates & secrets"
# 6. Copy tenant ID from overview

MICROSOFT_CLIENT_ID="your-azure-app-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-client-secret"
MICROSOFT_TENANT_ID="common"  # Use "common" for multi-tenant or your tenant ID
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# ----------------------------------------------------------------------------
# Email Service (Optional - for password reset emails)
# ----------------------------------------------------------------------------
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@sps-mot.dopravni.cz"
# SMTP_PASSWORD="your-email-password"
# SMTP_FROM="noreply@sps-mot.dopravni.cz"

# ----------------------------------------------------------------------------
# Bakaláři API Integration (Future)
# ----------------------------------------------------------------------------
# BAKALARI_API_URL="https://bakalari.spsd.cz/api"
# BAKALARI_API_KEY="your-api-key"

# ----------------------------------------------------------------------------
# Moodle API Integration (Future)
# ----------------------------------------------------------------------------
# MOODLE_URL="https://moodle.spsd.cz"
# MOODLE_API_TOKEN="your-moodle-token"

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------
# Encryption key for sensitive data (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-encryption-key-64-hex-characters-change-this-immediately"

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# ----------------------------------------------------------------------------
# Analytics & Monitoring (Optional)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# SENTRY_DSN="your-sentry-dsn"

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_EMAIL_RESET=false
ENABLE_TWO_FACTOR=false
ENABLE_AUDIT_LOGS=true
